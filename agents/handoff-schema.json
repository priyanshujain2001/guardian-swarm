{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Guardian Swarm Handoff",
  "type": "object",
  "required": ["task_id", "owner", "status", "confidence", "outputs"],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": ["queued", "running", "completed", "blocked"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "handoff_to": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "summary": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
